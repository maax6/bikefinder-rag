# PostgreSQL (docker-compose defaults, override if needed)
POSTGRES_USER=bikefinder
POSTGRES_PASSWORD=bikefinder
POSTGRES_DB=bikefinder
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Anthropic API key — required to run the agent locally (scripts/, eval/).
# The Gradio demo asks visitors for their own key instead of using this one.
ANTHROPIC_API_KEY=

# Agent backend: "anthropic" (default) or "ollama" for free local dev/testing
# (e.g. Mistral Small 3.2 via `ollama pull mistral-small3.2`, no API key needed).
AGENT_BACKEND=anthropic
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral-small3.2

# Once BGE-M3 is downloaded (first run), skip the HuggingFace Hub metadata
# ping at every model load — silences the "unauthenticated requests" warning
# and starts faster. Leave commented for the very first run (it downloads).
# HF_HUB_OFFLINE=1

# Scraper politeness
SCRAPER_DELAY_SECONDS=1.5
